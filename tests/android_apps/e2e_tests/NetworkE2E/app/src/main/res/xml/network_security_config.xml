<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Cleartext HTTP permitted to loopback only.
        Required for MiniHttpServer in runUrlAndHttpUrlConnectionTests.
        All other traffic uses the platform default (TLS only).
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>